<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.fruitveg.mapper.SysUserMapper">

    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.fruitveg.entity.SysUser">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectByPhone" parameterType="java.lang.String" resultType="com.fruitveg.entity.SysUser">
        SELECT * FROM sys_user WHERE phone = #{phone}
    </select>

</mapper>
